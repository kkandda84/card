# 아모레몰 로그인 정보
AMOREMALL_ID=your_id_here
AMOREMALL_PASSWORD=your_password_here

# 구매할 상품번호 (쉼표로 여러 개 입력 가능)
PRODUCT_NUMBERS=1234567,2345678

# 결제 수단 설정 (card, naver_pay, kakao_pay)
PAYMENT_METHOD=card

# 배송지 (기존 배송지 사용 시 비워두기)
# SHIPPING_NAME=홍길동
# SHIPPING_PHONE=01012345678
# SHIPPING_ADDRESS=서울시 강남구 ...

# 브라우저 설정
HEADLESS=false
SLOW_MO=100
